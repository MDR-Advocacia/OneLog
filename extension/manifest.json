{
  "manifest_version": 3,
  "name": "OneLog Pro - Enterprise",
  "version": "3.0",
  "description": "Acesso seguro, invisível e ininterrupto ao Portal Jurídico BB.",
  "permissions": [
    "cookies",
    "storage",
    "alarms",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "*://*.bb.com.br/*",
    "http://api-onelog.mdradvocacia.com/*",
    "http://localhost:5000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Acessar Portal"
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "spoof_ua",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  }
}